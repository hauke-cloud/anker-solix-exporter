# Example configuration file for Anker Solix Exporter
# Copy this file to config.yaml and adjust values

anker:
  # Your Anker account email
  email: "your.email@example.com"
  
  # Your Anker account password
  password: "your-password"
  
  # Country code (e.g., DE, US, UK, FR)
  country: "DE"
  
  # How often to poll for new data (e.g., 5m, 10m, 1h)
  # Recommended: 5-10 minutes to respect API rate limits
  poll_interval: "5m"
  
  # Enable debug logging for Anker API requests/responses
  # Set to true to see detailed API communication (useful for troubleshooting)
  # WARNING: Debug logs may contain sensitive data
  debug: false
  
  # Rate limiting configuration (based on Anker API limits)
  # Maximum number of requests per endpoint per minute (0 to disable)
  # Default: 10 (recommended to prevent API throttling)
  endpoint_limit: 10
  
  # Minimum delay between any API requests in seconds
  # Default: 0.3 (300ms, recommended for API stability)
  request_delay: 0.3

database:
  # TimescaleDB/PostgreSQL connection settings
  host: "localhost"
  port: 5432
  user: "anker_exporter"
  password: "your-db-password"
  database: "anker_solix"
  sslmode: "disable"
  
  # Path to migration files
  # Default: Auto-detects "/etc/anker-solix-exporter/migrations" (container) or "./migrations" (local)
  # migrations_path: "/etc/anker-solix-exporter/migrations"
  
  # Optional: TLS/SSL certificate-based authentication
  # Uncomment and configure for mTLS (mutual TLS) authentication
  # sslcert: "/path/to/client-cert.pem"      # Client certificate
  # sslkey: "/path/to/client-key.pem"        # Client private key
  # sslrootcert: "/path/to/ca-cert.pem"      # CA certificate
  #
  # Note: When using certificates, set sslmode to one of:
  # - "require": Require SSL/TLS but don't verify server certificate
  # - "verify-ca": Require SSL/TLS and verify server certificate against CA
  # - "verify-full": Require SSL/TLS, verify certificate and hostname

exporter:
  # Path to the resume state file
  # This file tracks the last exported timestamp for each device
  # Default: Auto-detects "/data/last_export.json" (container) or "./last_export.json" (local)
  # resume_file: "/data/last_export.json"
  
  # Log level: debug, info, warn, error
  log_level: "info"
